FROM ollama/ollama:latest

# 1. Open up the default Ollama network port environment variable
ENV OLLAMA_HOST=0.0.0.0:11434

# 2. Define the build argument (defaults to ollama if not passed)
ARG AI_PROVIDER=ollama
ARG OLLAMA_MODEL=qwen2.5:7b

# 3. Conditional build check: Only pull the model if AI_PROVIDER is explicitly 'ollama'
RUN if [ "$AI_PROVIDER" = "ollama" ]; then \
        echo "AI_PROVIDER is set to '$AI_PROVIDER', OLLAMA_MODEL is set to '$OLLAMA_MODEL'. Proceeding with the local LLM container build..." && \
        ollama serve & \
        sleep 5 && \
        ollama pull $OLLAMA_MODEL && \
        pkill ollama; \
    else \
        echo "AI_PROVIDER is set to '$AI_PROVIDER'. Skipping local LLM container build."; \
    fi

# Expose the network interface
EXPOSE 11434
